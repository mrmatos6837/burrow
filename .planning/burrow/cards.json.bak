{
  "version": 1,
  "ordering": "custom",
  "items": [
    {
      "id": "8eaff688",
      "title": "Phase 2 Decisions",
      "position": 0,
      "created": "2026-03-07T19:08:41.051Z",
      "archived": false,
      "notes": "Decisions from discuss-phase session 2026-03-07. Follow up on these during planning and execution.",
      "children": {
        "ordering": "custom",
        "items": [
          {
            "id": "ed71046f",
            "title": "Data Model Changes",
            "position": 0,
            "created": "2026-03-07T19:08:49.329Z",
            "archived": false,
            "notes": "These affect Phase 1 code. Must be done before or alongside Phase 2 features.",
            "children": {
              "ordering": "custom",
              "items": [
                {
                  "id": "365c4db1",
                  "title": "Drop position field",
                  "position": 0,
                  "created": "2026-03-07T19:09:16.895Z",
                  "archived": false,
                  "notes": "Array index IS the display order. recompact() goes away. addItem/moveItem simplify.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "f72c755e",
                  "title": "Drop ordering field",
                  "position": 1,
                  "created": "2026-03-07T19:09:16.941Z",
                  "archived": false,
                  "notes": "No more custom/alpha-asc/alpha-desc on containers. getOrderedChildren() just returns items as-is. Agent sorts on demand via move operations.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "64167976",
                  "title": "Rename notes to body",
                  "position": 2,
                  "created": "2026-03-07T19:09:16.980Z",
                  "archived": false,
                  "notes": "Generic free-form content field. Can store bug descriptions, ideas, agent instructions, format guidance. Parent body can instruct agent on how to interpret children.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "4d9da205",
                  "title": "Simplified item schema",
                  "position": 3,
                  "created": "2026-03-07T19:09:17.025Z",
                  "archived": false,
                  "notes": "{id, title, created, archived, body, children[]}",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                }
              ]
            }
          },
          {
            "id": "eb0e1b46",
            "title": "View System",
            "position": 1,
            "created": "2026-03-07T19:08:49.370Z",
            "archived": false,
            "notes": "get is the universal view command. Flat render array. Breadcrumbs for focus.",
            "children": {
              "ordering": "custom",
              "items": [
                {
                  "id": "cf06de46",
                  "title": "Flat render array",
                  "position": 0,
                  "created": "2026-03-07T19:09:17.065Z",
                  "archived": false,
                  "notes": "Each item: {id, title, depth, descendantCount, hasNotes, notesPreview, created, archived}. Pre-walked to requested depth. Agent indents by depth and appends (N).",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "390f9e31",
                  "title": "Depth model",
                  "position": 1,
                  "created": "2026-03-07T19:09:17.106Z",
                  "archived": false,
                  "notes": "No flag = item + direct children. --depth N = N levels of full details. --depth 0 = infinite/no cutoff. Items at cutoff show (N) active descendant count.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "ec4d8be4",
                  "title": "Breadcrumbs on focus",
                  "position": 2,
                  "created": "2026-03-07T19:09:17.146Z",
                  "archived": false,
                  "notes": "Focused subtree shows item as root + ancestry breadcrumbs. Presentation at Claude's discretion. Doesn't have to be inline with items.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "215053f8",
                  "title": "Archived excluded by default",
                  "position": 3,
                  "created": "2026-03-07T19:09:17.187Z",
                  "archived": false,
                  "notes": "Active views hide archived. Flag like --include-archived or --archived-only to see them.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                }
              ]
            }
          },
          {
            "id": "534624af",
            "title": "Archive Behavior",
            "position": 2,
            "created": "2026-03-07T19:08:49.410Z",
            "archived": false,
            "notes": "Cascade archive/unarchive. Active-only counts. Original tree position for archived views.",
            "children": {
              "ordering": "custom",
              "items": [
                {
                  "id": "d39bd117",
                  "title": "Cascade archive",
                  "position": 0,
                  "created": "2026-03-07T19:09:17.227Z",
                  "archived": false,
                  "notes": "Archiving a parent archives all descendants. The whole subtree disappears from active view.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "f719ed99",
                  "title": "Cascade unarchive",
                  "position": 1,
                  "created": "2026-03-07T19:09:17.267Z",
                  "archived": false,
                  "notes": "Symmetrical. Unarchiving restores the whole subtree.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "90772f1e",
                  "title": "Active-only descendant counts",
                  "position": 2,
                  "created": "2026-03-07T19:09:17.307Z",
                  "archived": false,
                  "notes": "If bugs has 5 children and 2 archived, count shows (3) not (5). Consistent with archived=hidden.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "af884490",
                  "title": "Archived tree position",
                  "position": 3,
                  "created": "2026-03-07T19:09:17.347Z",
                  "archived": false,
                  "notes": "When viewing archived items, show in original tree structure, not flattened.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                }
              ]
            }
          },
          {
            "id": "8a3c00ed",
            "title": "CLI Command Surface",
            "position": 3,
            "created": "2026-03-07T19:08:49.450Z",
            "archived": false,
            "notes": "Simplify to get as universal view. Aliases for list/dump/children. New archive/unarchive commands.",
            "children": {
              "ordering": "custom",
              "items": [
                {
                  "id": "b89b58ab",
                  "title": "get is universal view",
                  "position": 0,
                  "created": "2026-03-07T19:09:17.386Z",
                  "archived": false,
                  "notes": "get [id] [--depth N] covers all read operations. No separate render/list/dump/view commands.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "ad235fdb",
                  "title": "Aliases",
                  "position": 1,
                  "created": "2026-03-07T19:09:17.427Z",
                  "archived": false,
                  "notes": "list = get (no args). dump = get --depth 0. children = get <id>. path = get with breadcrumbs only. Same code path, DRY.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "c8b967cd",
                  "title": "New: archive/unarchive",
                  "position": 2,
                  "created": "2026-03-07T19:09:17.467Z",
                  "archived": false,
                  "notes": "archive <id> and unarchive <id>. Both cascade to descendants.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "ba72f4b4",
                  "title": "Stateless CLI",
                  "position": 3,
                  "created": "2026-03-07T19:09:17.508Z",
                  "archived": false,
                  "notes": "No persistent working directory. Agent holds context conversationally. Human steers with natural language, agent translates to IDs.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                }
              ]
            }
          },
          {
            "id": "6d10950b",
            "title": "Philosophy",
            "position": 4,
            "created": "2026-03-07T19:08:49.490Z",
            "archived": false,
            "notes": "No search command. Agent ingests + searches in memory. Same interface for humans and agents. Body field as self-documenting structure.",
            "children": {
              "ordering": "custom",
              "items": [
                {
                  "id": "14f0c60b",
                  "title": "No search command",
                  "position": 0,
                  "created": "2026-03-07T19:09:17.549Z",
                  "archived": false,
                  "notes": "Agent ingests tree via get --depth 0, searches in memory. Burrow is a structured dataset + view renderer, not a query engine.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "092234b9",
                  "title": "Same interface, different strengths",
                  "position": 1,
                  "created": "2026-03-07T19:09:17.589Z",
                  "archived": false,
                  "notes": "Human and agent use identical CLI. Agent advantage: bulk ingest full state, use direct ID commands. Human advantage: natural language via agent.",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                },
                {
                  "id": "d326666f",
                  "title": "Body as agent instructions",
                  "position": 2,
                  "created": "2026-03-07T19:09:17.630Z",
                  "archived": false,
                  "notes": "Parent body can describe schema/purpose of children. Self-documenting tree structures. E.g. 'Store bugs here. Title=description. Body=repro steps.'",
                  "children": {
                    "ordering": "custom",
                    "items": []
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
